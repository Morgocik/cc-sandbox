#!/usr/bin/env bash
set -euo pipefail

# ─── paths ────────────────────────────────────────────────────────────────────
TEMPLATES_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/cc-sandbox"

if ! command -v bwrap >/dev/null 2>&1; then
    echo "error: bwrap not found. Install the 'bubblewrap' package." >&2
    exit 1
fi

CLAUDE_BIN="${CLAUDE_BIN:-$(command -v claude 2>/dev/null)}"
if [[ -z "$CLAUDE_BIN" ]]; then
    echo "error: claude not found in PATH. Set CLAUDE_BIN to override." >&2
    exit 1
fi
CLAUDE_SHARE="${CLAUDE_SHARE:-$(dirname "$(dirname "$CLAUDE_BIN")")/share/claude}"

# ─── init command ─────────────────────────────────────────────────────────────
if [[ "${1:-}" == "init" ]]; then
    echo "Initializing cc-sandbox in: $PWD"

    # .cc-sandbox.conf
    if [[ -f ".cc-sandbox.conf" ]]; then
        echo "  [skip] .cc-sandbox.conf already exists"
    else
        cp "$TEMPLATES_DIR/.cc-sandbox.conf" ".cc-sandbox.conf"
        echo "  [ok]   .cc-sandbox.conf"
    fi

    # .gitignore — append cc-sandbox entries if not already present
    _gitignore_append() {
        if ! grep -qxF "$1" .gitignore 2>/dev/null; then
            echo "$1" >> .gitignore
            echo "  [ok]   .gitignore ($1)"
        else
            echo "  [skip] .gitignore ($1 already present)"
        fi
    }
    _gitignore_append '.cc-sandbox.conf'
    _gitignore_append '.cc-sandbox.log'

    echo "Done. Edit .cc-sandbox.conf to adjust mounts and environment variables."
    exit 0
fi

# ─── load per-project config ──────────────────────────────────────────────────
EXTRA_BIND_RO=""
EXTRA_BIND_RW=""
ENV_VARS=""
DEBUG=false

if [[ -f ".cc-sandbox.conf" ]]; then
    # shellcheck source=/dev/null
    source ".cc-sandbox.conf"
fi

# ─── build bwrap args ─────────────────────────────────────────────────────────
BWRAP_ARGS=()

# system — read only (guarded: /lib /bin may be split or merged into /usr)
BWRAP_ARGS+=(--ro-bind /usr /usr)
[[ -e /lib ]]   && BWRAP_ARGS+=(--ro-bind /lib /lib)
[[ -e /lib64 ]] && BWRAP_ARGS+=(--ro-bind /lib64 /lib64)
[[ -e /bin ]]   && BWRAP_ARGS+=(--ro-bind /bin /bin)

# /etc — only what's needed (each guarded; layouts differ across distros)
RESOLV="$(readlink -f /etc/resolv.conf 2>/dev/null || echo /etc/resolv.conf)"
[[ -e "$RESOLV" ]]      && BWRAP_ARGS+=(--ro-bind "$RESOLV" /etc/resolv.conf)
[[ -e /etc/hosts ]]     && BWRAP_ARGS+=(--ro-bind /etc/hosts /etc/hosts)
[[ -e /etc/ssl/certs ]] && BWRAP_ARGS+=(--ro-bind /etc/ssl/certs /etc/ssl/certs)
[[ -e /etc/pki ]]       && BWRAP_ARGS+=(--ro-bind /etc/pki /etc/pki)
[[ -e /etc/passwd ]]    && BWRAP_ARGS+=(--ro-bind /etc/passwd /etc/passwd)
[[ -e /etc/group ]]     && BWRAP_ARGS+=(--ro-bind /etc/group /etc/group)

# claude — read only (binary + runtime)
[[ -d "$CLAUDE_SHARE" ]] && BWRAP_ARGS+=(--ro-bind "$CLAUDE_SHARE" "$CLAUDE_SHARE")
BWRAP_ARGS+=(--ro-bind "$CLAUDE_BIN" "$CLAUDE_BIN")

# claude working data — cache, backups, changelog
mkdir -p "$HOME/.claude"
BWRAP_ARGS+=(--bind "$HOME/.claude" "$HOME/.claude")

# claude config & metadata — settings, preferences, userID
[[ -f "$HOME/.claude.json" ]] || echo '{}' > "$HOME/.claude.json"
BWRAP_ARGS+=(--bind "$HOME/.claude.json" "$HOME/.claude.json")

# git — global identity & config, read-only (Claude shells out to git; without
# this, commits fail with "Author identity unknown")
[[ -f "$HOME/.gitconfig" ]]   && BWRAP_ARGS+=(--ro-bind "$HOME/.gitconfig" "$HOME/.gitconfig")
[[ -d "$HOME/.config/git" ]]  && BWRAP_ARGS+=(--ro-bind "$HOME/.config/git" "$HOME/.config/git")

# project — read/write
BWRAP_ARGS+=(--bind "$PWD" "$PWD")

# extra mounts from .cc-sandbox.conf
for path in $EXTRA_BIND_RO; do
    [[ -e "$path" ]] && BWRAP_ARGS+=(--ro-bind "$path" "$path")
done
for path in $EXTRA_BIND_RW; do
    [[ -e "$path" ]] && BWRAP_ARGS+=(--bind "$path" "$path")
done

# /proc /dev /tmp
BWRAP_ARGS+=(--proc /proc)
BWRAP_ARGS+=(--dev /dev)
BWRAP_ARGS+=(--tmpfs /tmp)

# namespaces
BWRAP_ARGS+=(--unshare-all)
BWRAP_ARGS+=(--share-net)

# env
BWRAP_ARGS+=(--setenv HOME "$HOME")
BWRAP_ARGS+=(--setenv USER "${USER:-$(id -un)}")
for var in $ENV_VARS; do
    BWRAP_ARGS+=(--setenv "${var%%=*}" "${var#*=}")
done

# misc
BWRAP_ARGS+=(--die-with-parent)
BWRAP_ARGS+=(--new-session)
BWRAP_ARGS+=(--chdir "$PWD")

# ─── debug mode ──────────────────────────────────────────────────────────────
if [[ "$DEBUG" == "true" ]]; then
    echo "bwrap ${BWRAP_ARGS[*]} -- $CLAUDE_BIN $*" > .cc-sandbox.log
    echo "debug: command written to $PWD/.cc-sandbox.log"
    exit 0
fi

# ─── launch ───────────────────────────────────────────────────────────────────
exec bwrap "${BWRAP_ARGS[@]}" -- "$CLAUDE_BIN" "$@"
